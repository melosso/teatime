<Project>
  <PropertyGroup>
    <Authors>Melosso</Authors>
    <Product>Teatime</Product>
    <PackageProjectUrl>https://github.com/melosso/teatime</PackageProjectUrl>
    <RepositoryUrl>https://github.com/melosso/teatime</RepositoryUrl>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
  </PropertyGroup>

  <PropertyGroup>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
  </PropertyGroup>
</Project>
